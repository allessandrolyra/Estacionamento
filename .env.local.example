# Supabase - copie para .env.local e preencha
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Obrigatório para: criar primeiro admin (scripts/seed-admin.js) e gestão de usuários no painel
# Obtenha em: Supabase > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
